<div class="question-page">
  <div class="question-container">

    <div class="page-top">
      <div class="page-heading">
        <h1>Question List</h1>
        <p>Manage all interview questions from one place.</p>
      </div>
      <a href="/questions/new" class="btn btn-primary">+ Add Question</a>
    </div>

    <!-- Filters -->
    <div class="page-card">
      <div class="card-header">
        <h2>Filters</h2>
      </div>

      <form class="filter-form">
        <div class="form-group flex-1">
          <label>Category</label>
          <select id="category-filter">
            <option value="">All Categories</option>
            <option value="html">HTML</option>
            <option value="css">CSS</option>
            <option value="javascript">JavaScript</option>
            <option value="angular">Angular</option>
            <option value="react">React JS</option>
            <option value="python">Python</option>
          </select>
        </div>

        <div class="form-group flex-1">
          <label>Difficulty</label>
          <select id="difficulty-filter">
            <option value="">All Difficulty</option>
            <option value="easy">Easy</option>
            <option value="medium">Medium</option>
            <option value="hard">Hard</option>
          </select>
        </div>

        <div class="form-group flex-1">
          <label>Question Type</label>
          <select id="questionType-filter">
            <option value="">All</option>
            <option value="mcq">MCQ</option>
            <option value="boolean">BOOLEAN</option>
            <option value="multi_answer">MULTI_ANSWER</option>
          </select>
        </div>

        <div class="filter-actions">
          <button id="apply" class="btn btn-primary">Apply</button>
          <button id="reset" class="btn btn-secondary">Reset</button>
        </div>
      </form>
    </div>

    <!-- Table -->
    <div class="page-card">
      <div class="card-header card-header-row">
        <h2>Questions</h2>
        <span class="badge badge-primary"><%= pagination.total %> items</span>
      </div>

      <div class="table-wrapper">
        <div class="pagination-wrap">
            <div class="pagination-info">
                Showing <strong><%= ((pagination.page - 1) * pagination.limit + 1) %></strong> to <strong><%= Math.min(pagination.page * pagination.limit, pagination.total) %></strong> of <strong><%= pagination.total %></strong> questions
            </div>

            <div class="pagination">
                <% if (pagination.hasPrevPage) { %>
                    <a href="?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>&category=<%= category || '' %>&difficulty=<%= difficulty || '' %>&questionType=<%= questionType || '' %>" class="btn btn-secondary btn-sm">Prev</a>
                <% } else { %>
                    <a href="#" class="btn btn-secondary btn-sm disabled">Prev</a>
                <% } %>

                <% 
                const currentPage = pagination.page;
                const totalPages = pagination.totalPages;
                const pagesToShow = [];
                
                // Always show first 2 pages
                for (let i = 1; i <= Math.min(2, totalPages); i++) {
                    pagesToShow.push(i);
                }
                
                // Show current page if not already included
                if (currentPage > 2 && currentPage < totalPages - 1) {
                    if (pagesToShow[pagesToShow.length - 1] !== currentPage - 1) {
                        pagesToShow.push('...');
                    }
                    pagesToShow.push(currentPage);
                }
                
                // Show last 2 pages
                if (totalPages > 2) {
                    if (pagesToShow[pagesToShow.length - 1] !== totalPages - 2 && currentPage < totalPages - 2) {
                        pagesToShow.push('...');
                    }
                    for (let i = Math.max(totalPages - 1, 3); i <= totalPages; i++) {
                        if (!pagesToShow.includes(i)) {
                            pagesToShow.push(i);
                        }
                    }
                }
                
                pagesToShow.forEach(page => {
                %>
                    <% if (page === '...') { %>
                        <span class="pagination-dots">...</span>
                    <% } else if (page === currentPage) { %>
                        <a href="#" class="btn btn-primary btn-sm"><%= page %></a>
                    <% } else { %>
                        <a href="?page=<%= page %>&limit=<%= pagination.limit %>&category=<%= category || '' %>&difficulty=<%= difficulty || '' %>&questionType=<%= questionType || '' %>" class="btn btn-secondary btn-sm"><%= page %></a>
                    <% } %>
                <% }); %>

                <% if (pagination.hasNextPage) { %>
                    <a href="?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>&category=<%= category || '' %>&difficulty=<%= difficulty || '' %>&questionType=<%= questionType || '' %>" class="btn btn-secondary btn-sm">Next</a>
                <% } else { %>
                    <a href="#" class="btn btn-secondary btn-sm disabled">Next</a>
                <% } %>
            </div>
        </div>
        <table class="question-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Question</th>
              <th>Category</th>
              <th>Difficulty</th>
              <th>Type</th>
              <th style="min-width: 225px;">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (questions && questions.length > 0) { %>
              <% questions.forEach((question, index) => { %>
                <tr>
                  <td><%= ((pagination.page - 1) * pagination.limit + 1) + index %></td>
                  <td><%= question.question %></td>
                  <td><span class="badge uppercase badge-<%= question.category || 'info' %> capitalize"><%= question.category %></span></td>
                  <td><span class="uppercase badge badge-<%= question.difficulty === 'easy' ? 'success' : question.difficulty === 'medium' ? 'warning' : 'danger' %>"><%= question.difficulty %></span></td>
                  <td><span class="badge badge-secondary uppercase"><%= question.question_type %></span></td>
                  <td>
                    <div class="table-actions">
                      <!-- VIEW -->
                      <a href="/questions/detail/<%= question._id %>" class="btn btn-info btn-sm">
                        View
                      </a>

                      <!-- EDIT -->
                      <a href="/questions/edit/<%= question._id %>" class="btn btn-warning btn-sm">
                        Edit
                      </a>

                      <!-- DELETE -->
                      <form action="/questions/delete/<%= question._id %>" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-danger btn-sm"
                          onclick="return confirm('Are you sure you want to delete this question?')">
                          Delete
                        </button>
                      </form>

                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align:center; padding:20px;">
                  🚫 No questions found
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
<script>
  const apply = document.getElementById("apply");
  const reset = document.getElementById("reset");
  const category = document.getElementById("category-filter");
  const difficulty = document.getElementById("difficulty-filter");
  const questionType = document.getElementById("questionType-filter");

  (function setQueryFilterVal()  {
    const urlParams = new URLSearchParams(window.location.search);
    category.value =  urlParams.get('category') || "";
    difficulty.value = urlParams.get('difficulty') || "";
    questionType.value = urlParams.get('questionType') || "";
  })();

  apply.addEventListener('click', function(e) {
    e.preventDefault();
    let queryParams  = "";
    if (category.value) {
      queryParams +=  `category=${category.value}&`
    }
    if (difficulty.value) {
      queryParams +=  `difficulty=${difficulty.value}&`
    }
    if (questionType.value) {
      queryParams +=  `questionType=${questionType.value}&`
    }
    window.location.href = `/questions?${queryParams}page=1&limit=10`
  })
</script>