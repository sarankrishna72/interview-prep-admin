<div class="question-page">
  <div class="question-container">
    <div class="page-top">
      <div class="page-heading">
        <h1>Edit Question</h1>
        <p>Update the question details.</p>
      </div>
    </div>

    <div class="page-card">
      <div class="card-header">
        <h2>Question Form</h2>
      </div>

      <%- include('partials/form', {
        question,
        formAction: `/questions/${question._id}`,
        formMethod: 'PUT',
        submitLabel: 'Update Question',
        cancelUrl: `/questions/${question._id}`
      }) %>
    </div>
  </div>
</div>